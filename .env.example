POSTGRES_DB=chatai
POSTGRES_USER=chatai
POSTGRES_PASSWORD=chatai_password
DATABASE_URL=postgresql://chatai:chatai_password@db:5432/chatai
REDIS_URL=redis://redis:6379/0
SECRET_KEY=dev-secret-key-change-in-production

NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Google OAuth ──────────────────────────────────────────────────
# GCP コンソール (https://console.cloud.google.com/) で OAuth 2.0 クライアントを作成し、
# 以下の値を設定してください。
# 承認済みリダイレクト URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ─── Cookie 設定 ──────────────────────────────────────────────────
# HTTPS 環境では true に設定（ローカル開発は false）
COOKIE_SECURE=false

# ─── OpenAI ───────────────────────────────────────────────────────
# AI分析に使用。未設定の場合はルールベース分析にフォールバック。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── 開発用フラグ ─────────────────────────────────────────────────
# true  → dev-login モード: sessionStorage + Bearer token (開発用、Google 認証不要)
# false → Google OAuth モード: HttpOnly Cookie 認証 (本番運用)
DEV_LOGIN_ENABLED=true
NEXT_PUBLIC_DEV_LOGIN=true
